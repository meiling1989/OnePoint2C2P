@inherits LayoutComponentBase

<div class="dashboard-container">
    <nav class="sidebar" role="navigation" aria-label="Dashboard navigation">
        <div class="sidebar-header">
            <h2>OnePoint</h2>
            <span class="role-badge">@_role</span>
        </div>
        <ul class="nav-links">
            <li><a href="/dashboard" class="nav-link">Overview</a></li>
            <li><a href="/dashboard/transactions" class="nav-link">Transactions</a></li>
            @if (_role == "admin")
            {
                <li><a href="/dashboard/merchants" class="nav-link">Merchants</a></li>
            }
            <li><a href="/dashboard/loyalty-rules" class="nav-link">Loyalty Rules</a></li>
            <li><a href="/dashboard/promotions" class="nav-link">Promotions</a></li>
        </ul>
        <div class="sidebar-footer">
            <span>@_email</span>
            <a href="/dashboard/logout" class="nav-link logout-link">Logout</a>
        </div>
    </nav>
    <main class="main-content" role="main">
        @Body
    </main>
</div>

<style>
    .dashboard-container { display: flex; min-height: 100vh; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
    .sidebar { width: 240px; background: #1a1a2e; color: #eee; padding: 1rem; display: flex; flex-direction: column; }
    .sidebar-header h2 { margin: 0 0 0.25rem; color: #7c83ff; }
    .role-badge { font-size: 0.75rem; background: #7c83ff; color: #fff; padding: 2px 8px; border-radius: 4px; text-transform: uppercase; }
    .nav-links { list-style: none; padding: 0; margin: 2rem 0; flex: 1; }
    .nav-links li { margin-bottom: 0.25rem; }
    .nav-link { color: #ccc; text-decoration: none; padding: 0.5rem 0.75rem; display: block; border-radius: 4px; }
    .nav-link:hover { background: #16213e; color: #fff; }
    .sidebar-footer { border-top: 1px solid #333; padding-top: 1rem; font-size: 0.85rem; }
    .sidebar-footer span { display: block; margin-bottom: 0.5rem; color: #999; overflow: hidden; text-overflow: ellipsis; }
    .logout-link { color: #ff6b6b; }
    .main-content { flex: 1; padding: 2rem; background: #f5f5f5; overflow-y: auto; }
</style>

@code {
    private string _role = "";
    private string _email = "";

    protected override void OnInitialized()
    {
        // Read from cascading DashboardAuth state
    }

    [CascadingParameter]
    public DashboardAuthState? AuthState { get; set; }

    protected override void OnParametersSet()
    {
        if (AuthState is not null)
        {
            _role = AuthState.Role;
            _email = AuthState.Email;
        }
    }
}
