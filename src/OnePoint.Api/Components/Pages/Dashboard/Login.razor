@page "/dashboard/login"
@rendermode InteractiveServer
@inject Supabase.Client SupabaseClient
@inject DashboardService DashboardSvc
@inject DashboardAuthState AuthState
@inject NavigationManager Nav

<PageTitle>OnePoint Dashboard — Login</PageTitle>

<div class="login-container">
    <div class="login-card">
        <h1>OnePoint Dashboard</h1>
        <p class="subtitle">Merchant &amp; Admin Portal</p>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="error-banner" role="alert">@_errorMessage</div>
        }

        <div class="login-form">
            <label for="email">Email</label>
            <input id="email" type="email" @bind="_email" placeholder="you@company.com" disabled="@_loading" />

            <label for="password">Password</label>
            <input id="password" type="password" @bind="_password" placeholder="Password" disabled="@_loading"
                   @onkeydown="HandleKeyDown" />

            <button class="btn-primary" @onclick="LoginWithPassword" disabled="@_loading">
                @(_loading ? "Signing in…" : "Sign In")
            </button>

            <div class="divider"><span>or</span></div>

            <button class="btn-google" @onclick="LoginWithGoogle" disabled="@_loading">
                Sign in with Google
            </button>
        </div>
    </div>
</div>

<style>
    .login-container { display: flex; justify-content: center; align-items: center; min-height: 100vh; background: #f5f5f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }
    .login-card { background: #fff; padding: 2.5rem; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,0.1); width: 100%; max-width: 400px; }
    .login-card h1 { margin: 0 0 0.25rem; color: #1a1a2e; }
    .subtitle { color: #666; margin: 0 0 1.5rem; }
    .error-banner { background: #ffe0e0; color: #c00; padding: 0.75rem; border-radius: 4px; margin-bottom: 1rem; font-size: 0.9rem; }
    .login-form label { display: block; margin-bottom: 0.25rem; font-weight: 600; font-size: 0.9rem; color: #333; }
    .login-form input { width: 100%; padding: 0.6rem; margin-bottom: 1rem; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem; box-sizing: border-box; }
    .btn-primary { width: 100%; padding: 0.7rem; background: #7c83ff; color: #fff; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; }
    .btn-primary:hover { background: #6a70e0; }
    .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
    .divider { text-align: center; margin: 1rem 0; color: #999; position: relative; }
    .divider::before, .divider::after { content: ''; position: absolute; top: 50%; width: 40%; height: 1px; background: #ddd; }
    .divider::before { left: 0; }
    .divider::after { right: 0; }
    .btn-google { width: 100%; padding: 0.7rem; background: #fff; color: #333; border: 1px solid #ddd; border-radius: 4px; font-size: 1rem; cursor: pointer; }
    .btn-google:hover { background: #f9f9f9; }
</style>

@code {
    private string _email = "";
    private string _password = "";
    private string _errorMessage = "";
    private bool _loading;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoginWithPassword();
    }

    private async Task LoginWithPassword()
    {
        _errorMessage = "";
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _errorMessage = "Please enter both email and password.";
            return;
        }

        _loading = true;
        try
        {
            var session = await SupabaseClient.Auth.SignIn(_email, _password);
            if (session?.User is null)
            {
                _errorMessage = "Authentication failed. Please check your credentials.";
                return;
            }

            await ResolveRoleAndRedirect(session.User.Id ?? "", session.User.Email ?? _email, session.AccessToken ?? "");
        }
        catch (Exception)
        {
            _errorMessage = "Authentication failed. Please check your credentials.";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoginWithGoogle()
    {
        _errorMessage = "";
        _loading = true;
        try
        {
            // For MVP, Supabase SSO redirect. In a real app this would open a popup/redirect.
            // Blazor Server can't do OAuth redirects natively, so we simulate with email/password for demo.
            _errorMessage = "Google SSO: In production, this redirects to Google. For the demo, use email/password login with a seeded merchant_user account.";
            await Task.CompletedTask;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ResolveRoleAndRedirect(string authUserId, string email, string accessToken)
    {
        if (!Guid.TryParse(authUserId, out var authGuid))
        {
            _errorMessage = "Authentication failed. Invalid user identity.";
            return;
        }

        var merchantUser = await DashboardSvc.GetMerchantUserByAuthId(authGuid);
        if (merchantUser is null)
        {
            _errorMessage = "Access denied. No dashboard account found for this user.";
            return;
        }

        if (!merchantUser.IsActive)
        {
            _errorMessage = "Your account has been deactivated. Contact an administrator.";
            return;
        }

        AuthState.IsAuthenticated = true;
        AuthState.UserId = merchantUser.Id;
        AuthState.MerchantId = merchantUser.Role == "admin" ? null : merchantUser.MerchantId;
        AuthState.Role = merchantUser.Role;
        AuthState.Email = email;
        AuthState.AccessToken = accessToken;

        Nav.NavigateTo("/dashboard");
    }
}
