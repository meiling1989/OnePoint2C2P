@page "/dashboard/consumers"
@rendermode InteractiveServer
@layout DashboardLayout
@inject DashboardAuthState AuthState
@inject ConsumerService ConsumerSvc
@inject NavigationManager Nav

<PageTitle>OnePoint Dashboard — Consumers</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    <p>Redirecting…</p>
}
else
{
    <h1>Consumers</h1>

    <!-- Register New Consumer -->
    <div class="form-card">
        <h3>Register New Consumer</h3>
        @if (!string.IsNullOrEmpty(_formError))
        {
            <div class="error-banner" role="alert">@_formError</div>
        }
        @if (!string.IsNullOrEmpty(_formSuccess))
        {
            <div class="success-banner" role="status">@_formSuccess</div>
        }
        <div class="form-row">
            <div class="form-group">
                <label for="phoneNumber">Phone Number</label>
                <input id="phoneNumber" type="text" placeholder="+66812345678" @bind="_phoneNumber" />
            </div>
            <button class="btn-primary" @onclick="RegisterConsumer" disabled="@_saving">Register</button>
        </div>
    </div>

    <!-- Search / Filter -->
    <div class="filter-bar">
        <input type="text" placeholder="Search by name or phone…" @bind="_searchTerm" @bind:after="ApplyFilter" />
        <select @bind="_statusFilter" @bind:after="ApplyFilter">
            <option value="all">All</option>
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
        </select>
        <span class="result-count">@_filtered.Count consumer(s)</span>
    </div>

    <!-- Consumer List -->
    @if (_loading)
    {
        <p>Loading consumers…</p>
    }
    else
    {
        <table class="data-table" role="grid" aria-label="Consumer list">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Phone</th>
                    <th>Balance</th>
                    <th>QR Code</th>
                    <th>Active</th>
                    <th>Registered</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var c in _filtered)
                {
                    <tr>
                        <td>
                            @if (_editingId == c.Id)
                            {
                                <input type="text" @bind="_editName" style="width:140px;" />
                            }
                            else
                            {
                                @(c.DisplayName ?? "—")
                            }
                        </td>
                        <td>@c.PhoneNumber</td>
                        <td>@c.OnepointBalance.ToString("N0")</td>
                        <td><code>@c.QrCodeData</code></td>
                        <td>@(c.IsActive ? "✓" : "✗")</td>
                        <td>@c.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @if (_editingId == c.Id)
                            {
                                <button class="btn-sm btn-save" @onclick="SaveEdit">Save</button>
                                <button class="btn-sm" @onclick="CancelEdit">Cancel</button>
                            }
                            else
                            {
                                <button class="btn-sm" @onclick="() => StartEdit(c)">Edit</button>
                                @if (c.IsActive)
                                {
                                    <button class="btn-sm btn-danger" @onclick="() => Deactivate(c.Id)">Deactivate</button>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

<style>
    .form-card { background: #fff; padding: 1.25rem; border-radius: 8px; margin-bottom: 1rem; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
    .form-card h3 { margin: 0 0 0.75rem; }
    .form-row { display: flex; gap: 0.75rem; align-items: end; flex-wrap: wrap; }
    .form-group { display: flex; flex-direction: column; }
    .form-group label { font-size: 0.8rem; color: #666; margin-bottom: 0.25rem; }
    .form-group input { padding: 0.4rem; border: 1px solid #ddd; border-radius: 4px; min-width: 200px; }
    .error-banner { background: #ffe0e0; color: #c00; padding: 0.5rem; border-radius: 4px; margin-bottom: 0.75rem; font-size: 0.85rem; }
    .success-banner { background: #dcfce7; color: #166534; padding: 0.5rem; border-radius: 4px; margin-bottom: 0.75rem; font-size: 0.85rem; }
    .filter-bar { display: flex; gap: 0.75rem; align-items: center; margin-bottom: 1rem; }
    .filter-bar input { padding: 0.4rem; border: 1px solid #ddd; border-radius: 4px; min-width: 250px; }
    .filter-bar select { padding: 0.4rem; border: 1px solid #ddd; border-radius: 4px; }
    .result-count { font-size: 0.85rem; color: #666; }
    .btn-primary { padding: 0.45rem 1rem; background: #7c83ff; color: #fff; border: none; border-radius: 4px; cursor: pointer; }
    .btn-sm { padding: 0.25rem 0.5rem; font-size: 0.8rem; border: 1px solid #ddd; border-radius: 4px; background: #fff; cursor: pointer; margin-right: 0.25rem; }
    .btn-danger { color: #c00; border-color: #c00; }
    .btn-save { color: #166534; border-color: #166534; }
    .data-table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,0.06); }
    .data-table th, .data-table td { padding: 0.6rem 0.75rem; text-align: left; border-bottom: 1px solid #eee; }
    .data-table th { background: #fafafa; font-size: 0.85rem; color: #666; }
    .data-table code { background: #f5f5f5; padding: 0.1rem 0.3rem; border-radius: 3px; font-size: 0.8rem; }
</style>

@code {
    private List<Consumer> _consumers = new();
    private List<Consumer> _filtered = new();
    private bool _loading = true;
    private bool _saving;

    // Register form
    private string _phoneNumber = "";
    private string _formError = "";
    private string _formSuccess = "";

    // Filter
    private string _searchTerm = "";
    private string _statusFilter = "all";

    // Inline edit
    private Guid? _editingId;
    private string _editName = "";

    protected override async Task OnInitializedAsync()
    {
        if (!AuthState.IsAuthenticated) { Nav.NavigateTo("/dashboard/login"); return; }
        await LoadConsumers();
    }

    private async Task LoadConsumers()
    {
        _loading = true;
        try
        {
            _consumers = await ConsumerSvc.GetAllConsumers();
            ApplyFilter();
        }
        catch { _consumers = new(); _filtered = new(); }
        finally { _loading = false; }
    }

    private void ApplyFilter()
    {
        var q = _searchTerm?.Trim().ToLowerInvariant() ?? "";
        _filtered = _consumers.Where(c =>
        {
            if (_statusFilter == "active" && !c.IsActive) return false;
            if (_statusFilter == "inactive" && c.IsActive) return false;
            if (!string.IsNullOrEmpty(q))
            {
                var nameMatch = c.DisplayName?.ToLowerInvariant().Contains(q) == true;
                var phoneMatch = c.PhoneNumber.ToLowerInvariant().Contains(q);
                if (!nameMatch && !phoneMatch) return false;
            }
            return true;
        }).ToList();
    }

    private async Task RegisterConsumer()
    {
        _formError = ""; _formSuccess = "";
        if (string.IsNullOrWhiteSpace(_phoneNumber)) { _formError = "Phone number is required."; return; }

        _saving = true;
        try
        {
            var consumer = await ConsumerSvc.Register(_phoneNumber.Trim());
            _formSuccess = $"Registered {consumer.PhoneNumber} (ID: {consumer.Id})";
            _phoneNumber = "";
            await LoadConsumers();
        }
        catch (ValidationException ex) { _formError = ex.Message == "already-registered" ? "This phone number is already registered." : ex.Message; }
        catch (Exception) { _formError = "An error occurred. Please try again."; }
        finally { _saving = false; }
    }

    private void StartEdit(Consumer c)
    {
        _editingId = c.Id;
        _editName = c.DisplayName ?? "";
    }

    private void CancelEdit()
    {
        _editingId = null;
        _editName = "";
    }

    private async Task SaveEdit()
    {
        if (_editingId is null) return;
        _formError = "";
        try
        {
            await ConsumerSvc.UpdateProfile(_editingId.Value, new ProfileUpdateRequest(_editName));
            _editingId = null;
            await LoadConsumers();
        }
        catch (ValidationException ex) { _formError = ex.Message; }
        catch (Exception) { _formError = "Failed to update profile."; }
    }

    private async Task Deactivate(Guid consumerId)
    {
        _formError = "";
        try
        {
            await ConsumerSvc.DeactivateAccount(consumerId);
            await LoadConsumers();
        }
        catch (Exception ex) { _formError = ex.Message; }
    }
}
